rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/bookmarks/{bookmarkId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/sync_data/{recordId} {
      allow read, write: if isOwner(userId);
    }

    match /quran_bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /khatm_groups/{groupId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.created_by == request.auth.uid;
    }

    match /khatm_members/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && docId.split('__')[1] == request.auth.uid;
    }

    match /khatm_progress/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /content_flags/{flagId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    match /halal_reports/{barcode} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    match /daily_content/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /radios/{radioId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
